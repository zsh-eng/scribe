---
import Layout from "../../layouts/Layout.astro";
import SectionLabel from "../../components/SectionLabel.astro";
import MemberCard from "../../components/MemberCard.astro";
import Avatar from "../../components/Avatar.astro";
import {
  getMembersForParliament,
  getMemberCount,
  getAllMembersWithInfo,
  getParliaments,
  getLatestParliament,
} from "../../lib/db";
import { slugify } from "../../lib/slugify";

const parliaments = getParliaments(); // descending order (e.g. [15, 14, 13])
const latestParliament = getLatestParliament();
const allMembers = getAllMembersWithInfo();
const allMemberIds = new Set<string>();

// Build per-parliament member lists
const parliamentData = parliaments.map((p) => {
  const members = getMembersForParliament(p);
  members.forEach((m) => allMemberIds.add(m.id));
  return { parliament: p, members };
});

// Deduped flat list for search results (one card per member, overall stats)
// Use allMembers which has overall stats
const searchMembers = allMembers;

const STAGGER_LIMIT = 12;
const totalCount = getMemberCount();
---

<Layout title="MPs" description="Members of Parliament">
  <h1 class="font-display text-display-lg text-ink mb-4">
    Members of Parliament
  </h1>

  <div
    class="font-body text-base text-ink-soft leading-relaxed mb-8 space-y-3 text-pretty"
  >
    <p>
      Here, you can find the individual profiles of Members of Parliament (MPs)
      along with their records of their involvements in Parliament. The
      individual pages of each MP also have AI-generated summaries of their 20
      latest contributions in Parliament.
    </p>
    <p>
      In Singapore, there are three types of MPs: elected, non-constituency, and
      nominated.
    </p>

    <p>
      <strong class="text-ink">Elected MPs</strong> are voted in by members of the
      different constituencies in Singapore. These consistutencies are geographical
      divisions of Singapore drawn before every election by the Elections Department,
      which is under the Prime Minister's Office. Some of these MPs will be appointed
      to positions in the Government and become office holders. The rest of the elected
      MPs are known as backbenchers. Office holders include Ministers, Senior Ministers
      of State, Ministers of State, and Senior Parliamentary Secretaries.
    </p>
    <p>
      <strong class="text-ink">Non-Constituency Members (NCMPs)</strong> are declared
      as MPs from opposition parties who were not elected in the General Election,
      but received the highest percentage of votes amongst the unelected candidates
      from the opposition parties.
    </p>

    <p>
      <strong class="text-ink">Nominated Members (NMPs)</strong> are appointed by
      the President of Singapore and are meant to provide non-partisan views in Parliament.
    </p>

    <p>
      Don't know who your MP is? Enter your postal code in the map below to find
      out!
    </p>
    <div class="w-full overflow-hidden">
      <iframe
        title="2025 General Election Results Map"
        src="https://elections.data.gov.sg/en/map?isScrollable=true&primaryColor=%236253E8&view=Winning%20margin&lang=en&year=2025&constituenciesView=all"
        class="h-[980px] w-full border-none sm:h-[740px] md:h-[620px]"></iframe>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row gap-4 mb-6">
    <div class="flex-1">
      <div class="relative">
        <svg
          class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-ink/40 pointer-events-none"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <input
          type="text"
          id="member-search-input"
          class="w-full rounded-lg border border-border bg-surface px-4 py-2.5 pl-10 pr-10 font-ui text-sm text-ink placeholder:text-ink/40 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/20 transition-colors"
          placeholder="Search MPs (past and present) by name, constituency, or designation..."
          autocomplete="off"
          spellcheck="false"
        />
        <button
          type="button"
          id="member-search-clear"
          class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-ink/40 hover:text-ink transition-colors hidden"
          aria-label="Clear search"
        >
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <p
        id="member-search-status"
        class="mt-2 font-sans text-sm text-ink-muted hidden"
      >
      </p>
    </div>
    <div class="flex items-start gap-3">
      <select
        id="member-sort"
        class="rounded-lg border border-border bg-surface px-3 py-2.5 font-ui text-sm text-ink focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/20 transition-colors cursor-pointer"
      >
        <option value="name-asc">Name (A–Z)</option>
        <option value="involvements-desc">Most involvements</option>
        <option value="attendance-desc">Highest attendance</option>
      </select>
    </div>
  </div>

  <!-- Parliament dropdown sections (shown when not searching) -->
  <div id="parliament-sections">
    {
      parliamentData.map(({ parliament, members }, pIdx) => {
        const isCurrent = parliament === latestParliament;
        const parlLabel = isCurrent
          ? `Current (${parliament}th Parliament)`
          : `${parliament}th Parliament`;
        return (
          <details
            class="mb-6 parliament-group"
            open={isCurrent}
            data-parliament={parliament}
          >
            <summary class="cursor-pointer font-display text-lg text-ink mb-2 flex items-center gap-2 select-none hover:text-accent transition-colors list-none [&::-webkit-details-marker]:hidden">
              <svg
                class="w-4 h-4 text-ink-muted transition-transform duration-200 details-arrow shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 5l7 7-7 7"
                />
              </svg>
              {parlLabel}
              <span class="font-sans text-xs font-normal text-ink-muted bg-surface-alt px-2 py-0.5 rounded-full">
                {members.length}
              </span>
            </summary>

            <div
              class="grid gap-4 sm:grid-cols-2 mt-3 parliament-grid"
              data-parliament={parliament}
            >
              {members.map((member, i) => {
                const isStaggered = isCurrent && i < STAGGER_LIMIT;
                const attendancePercent =
                  member.attendanceTotal && member.attendanceTotal > 0
                    ? Math.round(
                        (member.attendancePresent! / member.attendanceTotal) *
                          100,
                      )
                    : 0;
                return (
                  <div
                    class={`member-item h-full${isStaggered ? " animate-fade-up" : ""}`}
                    style={
                      isStaggered
                        ? `animation-delay: ${0.1 + i * 0.03}s`
                        : undefined
                    }
                    data-name={member.name}
                    data-involvements={member.sectionCount || 0}
                    data-attendance={attendancePercent}
                    data-parliament={parliament}
                  >
                    <MemberCard member={member} />
                  </div>
                );
              })}
            </div>
          </details>
        );
      })
    }
  </div>

  <!-- Search results (hidden by default, shown when searching) -->
  <div id="search-results" class="hidden">
    <div id="search-results-grid" class="grid gap-4 sm:grid-cols-2">
      {
        searchMembers.map((member) => {
          const attendancePercent =
            member.attendanceTotal && member.attendanceTotal > 0
              ? Math.round(
                  (member.attendancePresent! / member.attendanceTotal) * 100,
                )
              : 0;
          return (
            <div
              class="search-member-item h-full"
              style="display: none;"
              data-name={member.name}
              data-member-id={member.id}
              data-involvements={member.sectionCount || 0}
              data-attendance={attendancePercent}
            >
              <MemberCard member={member} />
            </div>
          );
        })
      }
    </div>
  </div>

  <script>
    function initMemberPage() {
      const input = document.getElementById(
        "member-search-input",
      ) as HTMLInputElement | null;
      const clearBtn = document.getElementById(
        "member-search-clear",
      ) as HTMLButtonElement | null;
      const status = document.getElementById(
        "member-search-status",
      ) as HTMLElement | null;
      const select = document.getElementById(
        "member-sort",
      ) as HTMLSelectElement | null;
      const parliamentSections = document.getElementById("parliament-sections");
      const searchResults = document.getElementById("search-results");
      const searchGrid = document.getElementById("search-results-grid");

      if (
        !input ||
        !clearBtn ||
        !status ||
        !parliamentSections ||
        !searchResults ||
        !searchGrid
      )
        return;
      if (input.hasAttribute("data-search-initialized")) return;
      input.setAttribute("data-search-initialized", "true");

      const searchItems = Array.from(
        searchGrid.querySelectorAll(".search-member-item"),
      ) as HTMLElement[];

      // Sort within parliament grids
      if (select && !select.hasAttribute("data-sort-initialized")) {
        select.setAttribute("data-sort-initialized", "true");

        select.addEventListener("change", () => {
          const [key, dir] = select.value.split("-");

          // Sort parliament grids
          const grids = parliamentSections.querySelectorAll(
            ".parliament-grid",
          ) as NodeListOf<HTMLElement>;
          grids.forEach((grid) => {
            const items = Array.from(
              grid.querySelectorAll(".member-item"),
            ) as HTMLElement[];
            sortItems(items, key, dir);
            const fragment = document.createDocumentFragment();
            items.forEach((item) => fragment.appendChild(item));
            grid.appendChild(fragment);
          });

          // Also sort search results if visible
          if (!searchResults.classList.contains("hidden")) {
            const visibleItems = searchItems.filter(
              (i) => i.style.display !== "none",
            );
            sortItems(visibleItems, key, dir);
            const fragment = document.createDocumentFragment();
            visibleItems.forEach((i) => fragment.appendChild(i));
            // Append hidden ones after
            searchItems
              .filter((i) => i.style.display === "none")
              .forEach((i) => fragment.appendChild(i));
            searchGrid.appendChild(fragment);
          }
        });
      }

      function sortItems(items: HTMLElement[], key: string, dir: string) {
        items.sort((a, b) => {
          if (key === "name") {
            const aVal = (a.dataset.name || "").toLowerCase();
            const bVal = (b.dataset.name || "").toLowerCase();
            return dir === "asc"
              ? aVal.localeCompare(bVal)
              : bVal.localeCompare(aVal);
          }
          const aVal = parseInt(a.dataset[key] || "0", 10);
          const bVal = parseInt(b.dataset[key] || "0", 10);
          return dir === "asc" ? aVal - bVal : bVal - aVal;
        });
      }

      let debounceTimer: ReturnType<typeof setTimeout>;

      function performSearch(query: string) {
        const lowerQuery = query.toLowerCase().trim();

        if (!lowerQuery) {
          // Clear search: show parliament sections, hide search results
          parliamentSections.style.display = "";
          searchResults.classList.add("hidden");
          searchItems.forEach((item) => {
            item.style.display = "none";
          });
          status.classList.add("hidden");
          clearBtn.classList.add("hidden");
          return;
        }

        clearBtn.classList.remove("hidden");

        // Hide parliament sections, show search results
        parliamentSections.style.display = "none";
        searchResults.classList.remove("hidden");

        // Filter search items by text match
        let matchCount = 0;
        searchItems.forEach((item) => {
          const text = item.textContent?.toLowerCase() || "";
          if (text.includes(lowerQuery)) {
            item.style.display = "";
            matchCount++;
          } else {
            item.style.display = "none";
          }
        });

        status.textContent = `Found ${matchCount} result${matchCount !== 1 ? "s" : ""}`;
        status.classList.remove("hidden");
      }

      input.addEventListener("input", () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => performSearch(input.value), 150);
      });

      clearBtn.addEventListener("click", () => {
        input.value = "";
        performSearch("");
        input.focus();
      });

      input.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && input.value) {
          input.value = "";
          performSearch("");
        }
      });
    }

    initMemberPage();
    document.addEventListener("astro:after-swap", initMemberPage);
  </script>
</Layout>
