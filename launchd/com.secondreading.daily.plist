<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.secondreading.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/caffeinate</string>
    <string>-di</string>
    <string>/Users/admin/scribe/scripts/daily_pipeline.sh</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>13</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>WorkingDirectory</key>
  <string>/Users/admin/scribe</string>

  <key>StandardOutPath</key>
  <string>/Users/admin/Library/Logs/second-reading/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/admin/Library/Logs/second-reading/launchd.err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
