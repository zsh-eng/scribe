---
import Layout from "../../layouts/Layout.astro";
import SectionLabel from "../../components/SectionLabel.astro";
import QuestionCard from "../../components/QuestionCard.astro";
import BillCard from "../../components/BillCard.astro";
import Pagination from "../../components/Pagination.astro";
import Tag from "../../components/Tag.astro";
import {
  getAllMinistries,
  getMinistry,
  getMinistrySections,
  getMinistryBills,
  getMinistryParliamentStats,
  getLatestParliament,
} from "../../lib/db";
import { slugify } from "../../lib/slugify";

export async function getStaticPaths() {
  const ministries = getAllMinistries();
  return ministries.map((ministry) => ({
    params: { slug: slugify(ministry.name, ministry.id) },
    props: { id: ministry.id },
  }));
}

const { id } = Astro.props;
const ministry = getMinistry(id);

if (!ministry) {
  return Astro.redirect("/ministries");
}

const sections = getMinistrySections(id);
const bills = getMinistryBills(id);
const parliamentStats = getMinistryParliamentStats(id);
const latestParliament = getLatestParliament();

// Categorize sections
const oralQuestions = sections.filter((s) => s.sectionType === "OA");
const writtenQuestions = sections.filter((s) => s.sectionType === "WA");
const unansweredQuestions = sections.filter((s) => s.sectionType === "WANA");
const motions = sections.filter(
  (s) => s.category === "motion" || s.category === "adjournment_motion",
);
const clarifications = sections.filter((s) => s.category === "clarification");

const parliamentRows = parliamentStats.map((ps) => ({
  id: `parliament-${ps.parliament}`,
  label: `${ps.parliament}th Parliament`,
  shortLabel: `${ps.parliament}th`,
  isCurrent: ps.parliament === latestParliament,
  involvements: ps.involvements,
  oralQuestions: ps.oralQuestions,
  unansweredQuestions: ps.unansweredQuestions,
  writtenQuestions: ps.writtenQuestions,
  motions: ps.motions,
  bills: ps.bills,
}));

const overallParliamentRow = {
  id: "overall",
  label: "Overall",
  shortLabel: "Overall",
  isCurrent: false,
  involvements: sections.length + bills.length,
  oralQuestions: oralQuestions.length,
  unansweredQuestions: unansweredQuestions.length,
  writtenQuestions: writtenQuestions.length,
  motions: motions.length,
  bills: bills.length,
};

const allParliamentRows = [...parliamentRows, overallParliamentRow];
const mobileParliamentRows = [overallParliamentRow, ...parliamentRows];
---

<Layout
  title={ministry.name}
  description={`Parliamentary activities for ${ministry.name}`}
>
  <a
    href="/ministries"
    class="inline-flex items-center font-sans text-sm text-accent hover:text-accent-light no-underline mb-8"
  >
    ← Back to Ministries
  </a>

  <header class="mb-10">
    <div class="flex items-center gap-3 mb-3">
      <Tag color="green" class="text-sm px-0 py-1">{ministry.acronym}</Tag>
    </div>
    <h1 class="font-display text-display-md text-ink mb-2">
      {ministry.name}
    </h1>
    <p class="font-sans text-sm text-ink-muted">
      {ministry.sectionCount} total sections
    </p>
  </header>

  <!-- Parliament stats table -->
  {parliamentStats.length > 0 && (
    <div class="mb-8">
      <h4 class="font-sans text-sm font-semibold text-ink mb-3">
        Parliament activity
      </h4>

      <div class="hidden md:block overflow-x-auto rounded-lg border border-border">
        <table class="w-full min-w-[860px] text-left">
          <thead class="bg-surface-alt/70 border-b border-border">
            <tr>
              <th class="px-4 py-3 font-sans text-xs font-semibold tracking-wide text-ink-muted">
                Period
              </th>
              <th class="px-4 py-3 font-sans text-xs font-semibold tracking-wide text-ink-muted text-right">
                Total
              </th>
              <th class="px-4 py-3 font-sans text-xs font-semibold tracking-wide text-ink-muted text-right">
                Oral Questions
              </th>
              <th class="px-4 py-3 font-sans text-xs font-semibold tracking-wide text-ink-muted text-right">
                Oral Questions (Unanswered)
              </th>
              <th class="px-4 py-3 font-sans text-xs font-semibold tracking-wide text-ink-muted text-right">
                Written Questions
              </th>
              <th class="px-4 py-3 font-sans text-xs font-semibold tracking-wide text-ink-muted text-right">
                Motions
              </th>
              <th class="px-4 py-3 font-sans text-xs font-semibold tracking-wide text-ink-muted text-right">
                Bills
              </th>
            </tr>
          </thead>
          <tbody>
            {
              allParliamentRows.map((row, index) => (
                <tr
                  class:list={[
                    "border-b border-border last:border-0",
                    index % 2 === 0 ? "bg-white" : "bg-surface-alt/20",
                    row.isCurrent && "bg-amber-50/70",
                  ]}
                >
                  <td class="px-4 py-3 font-sans text-sm text-ink">
                    <div class="flex items-center gap-2">
                      <span>{row.label}</span>
                      {
                        row.isCurrent && (
                          <span class="font-sans text-[10px] uppercase tracking-wide text-accent bg-white border border-accent/30 px-1.5 py-0.5 rounded-full">
                            Current
                          </span>
                        )
                      }
                    </div>
                  </td>
                  <td class="px-4 py-3 text-right font-display text-lg text-ink">
                    {row.involvements}
                  </td>
                  <td class="px-4 py-3 text-right font-display text-lg text-ink">
                    {row.oralQuestions}
                  </td>
                  <td class="px-4 py-3 text-right font-display text-lg text-ink">
                    {row.unansweredQuestions}
                  </td>
                  <td class="px-4 py-3 text-right font-display text-lg text-ink">
                    {row.writtenQuestions}
                  </td>
                  <td class="px-4 py-3 text-right font-display text-lg text-ink">
                    {row.motions}
                  </td>
                  <td class="px-4 py-3 text-right font-display text-lg text-ink">
                    {row.bills}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <div class="md:hidden" data-parliament-switcher>
        <div
          class="ministry-parliament-controls mb-3"
          role="tablist"
          aria-label="Parliament activity period"
        >
          {
            mobileParliamentRows.map((row, index) => (
              <button
                type="button"
                role="tab"
                class:list={[
                  "ministry-parliament-mode-btn",
                  index === 0 && "is-active",
                ]}
                data-parliament-target={row.id}
                aria-selected={index === 0 ? "true" : "false"}
                tabindex={index === 0 ? 0 : -1}
              >
                <span>{row.shortLabel}</span>
                {
                  row.isCurrent && (
                    <span class="ministry-parliament-mode-pill">[current]</span>
                  )
                }
              </button>
            ))
          }
        </div>

        <div class="space-y-3">
          {
            mobileParliamentRows.map((row, index) => (
              <article
                class:list={[
                  "ministry-parliament-panel rounded-lg border border-border bg-surface p-4",
                  row.isCurrent && "ring-1 ring-accent/35",
                  index !== 0 && "hidden",
                ]}
                data-parliament-panel={row.id}
                hidden={index !== 0}
                role="tabpanel"
              >
                <div class="flex items-center justify-between gap-2 mb-3">
                  <h5 class="font-sans text-sm font-semibold text-ink">
                    {row.label}
                  </h5>
                  {
                    row.isCurrent && (
                      <span class="font-sans text-[10px] uppercase tracking-wide text-accent">
                        Current
                      </span>
                    )
                  }
                </div>
                <dl class="grid grid-cols-2 gap-x-3 gap-y-2">
                  <div class="flex items-baseline justify-between col-span-2 border-b border-border/70 pb-2 mb-1">
                    <dt class="font-sans text-xs text-ink-muted">Total</dt>
                    <dd class="font-display text-2xl text-ink">
                      {row.involvements}
                    </dd>
                  </div>
                  <div class="flex items-center justify-between">
                    <dt class="font-sans text-xs text-ink-muted">
                      Oral Questions
                    </dt>
                    <dd class="font-display text-base text-ink">
                      {row.oralQuestions}
                    </dd>
                  </div>
                  <div class="flex items-center justify-between">
                    <dt class="font-sans text-xs text-ink-muted">
                      Oral Questions (Unanswered)
                    </dt>
                    <dd class="font-display text-base text-ink">
                      {row.unansweredQuestions}
                    </dd>
                  </div>
                  <div class="flex items-center justify-between">
                    <dt class="font-sans text-xs text-ink-muted">
                      Written Questions
                    </dt>
                    <dd class="font-display text-base text-ink">
                      {row.writtenQuestions}
                    </dd>
                  </div>
                  <div class="flex items-center justify-between">
                    <dt class="font-sans text-xs text-ink-muted">Motions</dt>
                    <dd class="font-display text-base text-ink">
                      {row.motions}
                    </dd>
                  </div>
                  <div class="flex items-center justify-between">
                    <dt class="font-sans text-xs text-ink-muted">Bills</dt>
                    <dd class="font-display text-base text-ink">{row.bills}</dd>
                  </div>
                </dl>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  )}

  <!-- Unified search across all sections -->
  <div class="mb-8" data-pagefind-ignore data-ministry-name={ministry.name}>
    <div class="relative">
      <svg
        class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-ink/40 pointer-events-none"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
      <input
        type="text"
        id="ministry-search-input"
        class="w-full rounded-lg border border-border bg-surface px-4 py-2.5 pl-10 pr-10 font-ui text-sm text-ink placeholder:text-ink/40 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/20 transition-colors"
        placeholder="Search parliamentary activity related to this ministry..."
        autocomplete="off"
        spellcheck="false"
      />
      <button
        type="button"
        id="ministry-search-clear"
        class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-ink/40 hover:text-ink transition-colors hidden"
        aria-label="Clear search"
      >
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <p
      id="ministry-search-status"
      class="mt-2 font-sans text-sm text-ink-muted hidden"
    >
    </p>
  </div>

  <!-- Bills -->
  {
    bills.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-xl text-ink mb-4">
          Bills{" "}
          <span class="font-sans text-sm text-ink-muted font-normal">
            ({bills.length})
          </span>
        </h2>
        <div id="bills-list" class="flex flex-col border-t border-border">
          {bills.map((bill) => (
            <div class="bill-item">
              <div class="hidden" data-pagefind-body>
                <span data-pagefind-meta={`id:${bill.id}`} />
                <span data-pagefind-filter={`ministry:${ministry.name}`} />
              </div>
              <BillCard bill={bill} />
            </div>
          ))}
        </div>
        <Pagination
          containerId="bills-list"
          itemSelector=".bill-item"
          itemsPerPage={10}
        />
      </section>
    )
  }

  <!-- Motions -->
  {
    motions.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-xl text-ink mb-4">
          Motions{" "}
          <span class="font-sans text-sm text-ink-muted font-normal">
            ({motions.length})
          </span>
        </h2>
        <div id="motions-list" class="flex flex-col border-t border-border">
          {motions.map((section) => (
            <div class="motion-item">
              <div class="hidden" data-pagefind-body>
                <span data-pagefind-meta={`id:${section.id}`} />
                <span data-pagefind-filter={`ministry:${ministry.name}`} />
              </div>
              <QuestionCard section={section} />
            </div>
          ))}
        </div>
        <Pagination
          containerId="motions-list"
          itemSelector=".motion-item"
          itemsPerPage={10}
        />
      </section>
    )
  }

  <!-- Clarifications -->
  {
    clarifications.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-xl text-ink mb-4">
          Clarifications{" "}
          <span class="font-sans text-sm text-ink-muted font-normal">
            ({clarifications.length})
          </span>
        </h2>
        <div
          id="clarifications-list"
          class="flex flex-col border-t border-border"
        >
          {clarifications.map((section) => (
            <div class="clarification-item">
              <div class="hidden" data-pagefind-body>
                <span data-pagefind-meta={`id:${section.id}`} />
                <span data-pagefind-filter={`ministry:${ministry.name}`} />
              </div>
              <QuestionCard section={section} />
            </div>
          ))}
        </div>
        <Pagination
          containerId="clarifications-list"
          itemSelector=".clarification-item"
          itemsPerPage={10}
        />
      </section>
    )
  }

  <!-- Oral Questions -->
  {
    oralQuestions.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-xl text-ink mb-4">
          Oral Questions{" "}
          <span class="font-sans text-sm text-ink-muted font-normal">
            ({oralQuestions.length})
          </span>
        </h2>
        <div id="oral-questions-list" class="flex flex-col border-t border-border">
          {oralQuestions.map((section) => (
            <div class="oral-question-item">
              <div class="hidden" data-pagefind-body>
                <span data-pagefind-meta={`id:${section.id}`} />
                <span data-pagefind-filter={`ministry:${ministry.name}`} />
              </div>
              <QuestionCard section={section} />
            </div>
          ))}
        </div>
        <Pagination
          containerId="oral-questions-list"
          itemSelector=".oral-question-item"
          itemsPerPage={10}
        />
      </section>
    )
  }

  <!-- Unanswered Oral Questions -->
  {
    unansweredQuestions.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-xl text-ink mb-4">
          Unanswered Oral Questions with Written Answers{" "}
          <span class="font-sans text-sm text-ink-muted font-normal">
            ({unansweredQuestions.length})
          </span>
        </h2>
        <div id="unanswered-questions-list" class="flex flex-col border-t border-border">
          {unansweredQuestions.map((section) => (
            <div class="unanswered-question-item">
              <div class="hidden" data-pagefind-body>
                <span data-pagefind-meta={`id:${section.id}`} />
                <span data-pagefind-filter={`ministry:${ministry.name}`} />
              </div>
              <QuestionCard section={section} />
            </div>
          ))}
        </div>
        <Pagination
          containerId="unanswered-questions-list"
          itemSelector=".unanswered-question-item"
          itemsPerPage={10}
        />
      </section>
    )
  }

  <!-- Written Questions -->
  {
    writtenQuestions.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-xl text-ink mb-4">
          Written Questions{" "}
          <span class="font-sans text-sm text-ink-muted font-normal">
            ({writtenQuestions.length})
          </span>
        </h2>
        <div id="written-questions-list" class="flex flex-col border-t border-border">
          {writtenQuestions.map((section) => (
            <div class="written-question-item">
              <div class="hidden" data-pagefind-body>
                <span data-pagefind-meta={`id:${section.id}`} />
                <span data-pagefind-filter={`ministry:${ministry.name}`} />
              </div>
              <QuestionCard section={section} />
            </div>
          ))}
        </div>
        <Pagination
          containerId="written-questions-list"
          itemSelector=".written-question-item"
          itemsPerPage={10}
        />
      </section>
    )
  }

  {
    sections.length === 0 && bills.length === 0 && (
      <p class="py-12 text-center font-body text-ink-muted">
        No parliamentary activities found for this ministry.
      </p>
    )
  }

  <style is:global>
    .ministry-parliament-controls {
      display: inline-flex;
      width: fit-content;
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      border: 1px solid var(--border);
      scrollbar-width: none;
    }

    .ministry-parliament-controls::-webkit-scrollbar {
      display: none;
    }

    .ministry-parliament-mode-btn {
      border: 0;
      border-right: 1px solid var(--border);
      background: transparent;
      color: var(--ink-muted);
      padding: 6px 10px;
      font-family: "DM Sans", system-ui, sans-serif;
      font-size: 12px;
      line-height: 1.2;
      white-space: nowrap;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
    }

    .ministry-parliament-mode-btn:last-child {
      border-right: 0;
    }

    .ministry-parliament-mode-btn.is-active {
      background: var(--ink);
      color: var(--page-bg);
    }

    .ministry-parliament-mode-pill {
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-size: 10px;
      line-height: 1;
      padding: 2px 2px;
    }
  </style>
  <script>
    interface PagefindResult {
      id: string;
      data: () => Promise<{
        meta?: { id?: string };
        url: string;
        excerpt: string;
      }>;
    }

    interface PagefindSearch {
      results: PagefindResult[];
    }

    interface Pagefind {
      search: (
        query: string,
        options?: { filters?: Record<string, string> },
      ) => Promise<PagefindSearch>;
    }

    let pagefind: Pagefind | null = null;

    async function loadPagefind(): Promise<Pagefind | null> {
      if (pagefind) return pagefind;
      try {
        const base = import.meta.env.BASE_URL || "/";
        const pagefindPath = `${base}pagefind/pagefind.js`.replace(/\/+/g, "/");
        pagefind = (await import(/* @vite-ignore */ pagefindPath)) as Pagefind;
        return pagefind;
      } catch {
        return null;
      }
    }

    function initParliamentSwitcher() {
      const switchers = Array.from(
        document.querySelectorAll("[data-parliament-switcher]"),
      ) as HTMLElement[];

      for (const switcher of switchers) {
        if (switcher.hasAttribute("data-parliament-switcher-initialized")) {
          continue;
        }
        switcher.setAttribute("data-parliament-switcher-initialized", "true");

        const buttons = Array.from(
          switcher.querySelectorAll("[data-parliament-target]"),
        ) as HTMLButtonElement[];
        const panels = Array.from(
          switcher.querySelectorAll("[data-parliament-panel]"),
        ) as HTMLElement[];

        if (buttons.length === 0 || panels.length === 0) continue;

        const setActivePanel = (targetId: string) => {
          for (const button of buttons) {
            const isActive = button.dataset.parliamentTarget === targetId;
            button.classList.toggle("is-active", isActive);
            button.setAttribute("aria-selected", isActive ? "true" : "false");
            button.tabIndex = isActive ? 0 : -1;
          }

          for (const panel of panels) {
            const isActive = panel.dataset.parliamentPanel === targetId;
            panel.classList.toggle("hidden", !isActive);
            panel.hidden = !isActive;
          }
        };

        for (const button of buttons) {
          button.addEventListener("click", () => {
            const targetId = button.dataset.parliamentTarget;
            if (!targetId) return;
            setActivePanel(targetId);
          });
        }

        const initialTarget =
          buttons.find((button) => button.classList.contains("is-active"))
            ?.dataset.parliamentTarget || buttons[0]?.dataset.parliamentTarget;
        if (initialTarget) {
          setActivePanel(initialTarget);
        }
      }
    }

    function initMinistrySearch() {
      const wrapper = document.querySelector(
        "[data-ministry-name]",
      ) as HTMLElement;
      if (!wrapper) return;
      const ministryName = wrapper.getAttribute("data-ministry-name")!;

      const input = document.getElementById(
        "ministry-search-input",
      ) as HTMLInputElement;
      const clearBtn = document.getElementById(
        "ministry-search-clear",
      ) as HTMLButtonElement;
      const status = document.getElementById(
        "ministry-search-status",
      ) as HTMLElement;
      if (!input) return;
      if (input.hasAttribute("data-search-initialized")) return;
      input.setAttribute("data-search-initialized", "true");

      const sectionConfigs = [
        { id: "bills-list", selector: ".bill-item" },
        { id: "motions-list", selector: ".motion-item" },
        { id: "clarifications-list", selector: ".clarification-item" },
        { id: "oral-questions-list", selector: ".oral-question-item" },
        { id: "written-questions-list", selector: ".written-question-item" },
        { id: "unanswered-questions-list", selector: ".unanswered-question-item" },
      ]
        .map((s) => {
          const container = document.getElementById(s.id);
          if (!container) return null;
          const sectionEl = container.closest("section");
          const items = Array.from(
            container.querySelectorAll(s.selector),
          ) as HTMLElement[];
          return { container, sectionEl, items };
        })
        .filter(Boolean) as {
        container: HTMLElement;
        sectionEl: Element | null;
        items: HTMLElement[];
      }[];

      function getItemId(item: HTMLElement): string | null {
        return (
          item.getAttribute("data-search-id") ||
          item
            .querySelector("[data-search-id]")
            ?.getAttribute("data-search-id") ||
          null
        );
      }

      let debounceTimer: ReturnType<typeof setTimeout>;
      let searchSeq = 0;

      function updateSections(
        matchingIds: Set<string> | null,
        lowerQuery: string,
      ) {
        let totalMatches = 0;
        for (const sec of sectionConfigs) {
          let sectionMatches = 0;
          for (const item of sec.items) {
            let isMatch: boolean;
            if (matchingIds !== null) {
              const id = getItemId(item);
              isMatch = id !== null && matchingIds.has(id);
            } else {
              const text = item.textContent?.toLowerCase() || "";
              isMatch = text.includes(lowerQuery);
            }
            if (isMatch) {
              item.style.display = "";
              item.removeAttribute("data-search-hidden");
              sectionMatches++;
            } else {
              item.style.display = "none";
              item.setAttribute("data-search-hidden", "true");
            }
          }
          if (sec.sectionEl) {
            (sec.sectionEl as HTMLElement).style.display =
              sectionMatches === 0 ? "none" : "";
          }
          totalMatches += sectionMatches;
          sec.container.dispatchEvent(
            new CustomEvent("search-updated", {
              detail: { matchCount: sectionMatches, reordered: false },
            }),
          );
        }
        status.textContent = `Found ${totalMatches} result${totalMatches !== 1 ? "s" : ""}`;
        status.classList.remove("hidden");
      }

      async function performSearch(query: string) {
        const seq = ++searchSeq;
        const lowerQuery = query.toLowerCase().trim();

        if (!lowerQuery) {
          for (const sec of sectionConfigs) {
            if (sec.sectionEl)
              (sec.sectionEl as HTMLElement).style.display = "";
            for (const item of sec.items) {
              item.style.display = "";
              item.removeAttribute("data-search-hidden");
            }
            sec.container.dispatchEvent(
              new CustomEvent("search-cleared", {
                detail: { reordered: false },
              }),
            );
          }
          status.classList.add("hidden");
          clearBtn.classList.add("hidden");
          return;
        }

        clearBtn.classList.remove("hidden");

        const pf = await loadPagefind();
        if (seq !== searchSeq) return;

        if (pf) {
          const results = await pf.search(query, {
            filters: { ministry: ministryName },
          });
          if (seq !== searchSeq) return;

          // Fetch all fragments in parallel
          const allFragments = await Promise.all(
            results.results.map((r) => r.data()),
          );
          if (seq !== searchSeq) return;

          const orderedIds: string[] = [];
          for (const data of allFragments) {
            if (data.meta?.id) {
              orderedIds.push(data.meta.id);
            }
          }
          const matchingIds = new Set<string>(orderedIds);

          updateSections(matchingIds, lowerQuery);
          return;
        }

        // Fallback: text matching
        updateSections(null, lowerQuery);
      }

      input.addEventListener("input", () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => performSearch(input.value), 100);
      });

      clearBtn.addEventListener("click", () => {
        input.value = "";
        performSearch("");
        input.focus();
      });

      input.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && input.value) {
          input.value = "";
          performSearch("");
        }
      });

      input.addEventListener(
        "focus",
        () => {
          loadPagefind();
        },
        { once: true },
      );
    }

    function initMinistryPage() {
      initParliamentSwitcher();
      initMinistrySearch();
    }

    initMinistryPage();
    document.addEventListener("astro:after-swap", initMinistryPage);
  </script>
</Layout>
